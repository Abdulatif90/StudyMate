# Copy this file to `.env` and fill in real values. Never commit `.env`.

ENVIRONMENT=development
DEBUG=true

# --- Phase 0: Neon + Clerk (app/core/db.py, app/core/auth.py read these) ---
DATABASE_URL=postgresql://user:password@host/dbname
CLERK_JWKS_URL=https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-app>.clerk.accounts.dev

# --- Phase 1: Cohere embeddings (app/modules/documents/embedding.py reads this) ---
COHERE_API_KEY=...

# --- Phase 1: Claude generation (app/modules/ask/llm.py reads this) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Phase 1: Inngest (async document processing — app/core/inngest_client.py) ---
# From your Inngest app's keys. Local dev also needs the Inngest Dev Server running
# (`npx inngest-cli@latest dev`); the app serves its functions at /api/inngest.
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...

# --- Phase 1: Cloudflare R2 (uploaded-file storage — app/core/r2_client.py) ---
# From your R2 bucket + an R2 API token (S3-compatible). The endpoint is derived as
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...

# --- Phase 4: Polar (billing / Merchant of Record — app/core/polar_client.py) ---
# POLAR_ACCESS_TOKEN: an *organization* access token (starts with `polar_oat_`) from
# the Polar dashboard -> Settings -> Developers. Grants API access for your org.
POLAR_ACCESS_TOKEN=polar_oat_...
# Which Polar environment to talk to: "sandbox" (default) or "production". Sandbox is
# the default so a misconfigured deploy can never charge a real card by accident;
# production is an explicit opt-in. Sandbox has its OWN dashboard, products and tokens
# (sandbox.polar.sh) — a production token will not work against sandbox or vice versa.
POLAR_SERVER=sandbox
# POLAR_WEBHOOK_SECRET: the signing secret for the webhook endpoint. Either from
# dashboard -> Settings -> Webhooks -> your endpoint, or printed by `polar listen`
# (the CLI tunnel used for local dev) — these are DIFFERENT secrets, so use the one
# matching however the events are actually being delivered. Never optional at runtime:
# an unverified webhook is an entitlement bypass (anyone could POST themselves onto a
# paid plan), so a missing value raises rather than accepting unsigned events.
POLAR_WEBHOOK_SECRET=...
# Product ids for the paid plans, from the Polar dashboard (or `products.list()`).
# Mapped by **id, not name** — names are mutable labels, ids are stable (see
# app/core/config.py). Both products must be RECURRING (monthly/yearly): a one-time
# product never emits the subscription.* events this integration listens for, so plans
# would never change. There is no Free product id on purpose — Free is the absence of a
# paid plan, so it is never sold.
POLAR_PRODUCT_ID_PRO=...
POLAR_PRODUCT_ID_BUSINESS=...

# --- Frontend (CORS) — comma-separated, defaults to http://localhost:3000 ---
# CORS_ORIGINS=http://localhost:3000
